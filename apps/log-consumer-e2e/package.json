{
  "name": "@human-resource-management/log-consumer-e2e",
  "version": "0.0.1",
  "private": true,
  "nx": {
    "name": "log-consumer-e2e",
    "implicitDependencies": [
      "log-consumer"
    ],
    "targets": {
      "e2e": {
        "executor": "@nx/jest:jest",
        "outputs": [
          "{projectRoot}/test-output/jest/coverage"
        ],
        "options": {
          "jestConfig": "apps/log-consumer-e2e/jest.config.cts",
          "passWithNoTests": true
        },
        "dependsOn": [
          "log-consumer:build",
          "log-consumer:serve"
        ]
      }
    }
  }
}
