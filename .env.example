# -------------------------------------------------------
# Root .env — used by both local development and docker-compose.
# Copy to .env and fill in the required values.
#
# Host values below use localhost, which is correct for local development.
# When running via docker-compose, POSTGRES_HOST and REDIS_HOST are
# automatically overridden to the service names defined in docker-compose.yml
# — you do not need to change them here for Docker.
# -------------------------------------------------------

# PostgreSQL (shared by all services, databases are created by docker/init-db.sh)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=hrm_user
POSTGRES_PASSWORD=change_me
POSTGRES_EMPLOYEE_DB=employee_db
POSTGRES_ATTENDANCE_DB=attendance_db
POSTGRES_AUDIT_DB=audit_db

# JWT (must be the same value across gateway and employee-service)
JWT_SECRET=
JWT_EXPIRES_IN=1d

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Upstream service URLs (used by gateway to proxy requests)
# Local development: use localhost with each service's port
# Docker: automatically overridden to service names by docker-compose.yml
EMPLOYEE_SERVICE_URL=http://localhost:3001
ATTENDANCE_SERVICE_URL=http://localhost:3002

# React app build-time variable (baked into the JS bundle at build time)
# Local development: http://localhost:3000/api
# Docker: same value works since the browser always connects from the host machine
VITE_BASE_API_URL=http://localhost:3000/api
