{
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "target": "es2021",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "strict": true,
    "skipLibCheck": true,
    "paths": {
      "@human-resource-management/common": ["./libs/common/src/index.ts"],
      "@human-resource-management/shared-types": ["./libs/shared-types/src/index.ts"]
    }
  },
  "include": [
    "apps/employee-service/src/**/*.ts",
    "apps/attendance-service/src/**/*.ts",
    "apps/log-consumer/src/**/*.ts",
    "libs/**/*.ts"
  ]
}
